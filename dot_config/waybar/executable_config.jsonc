// -*- mode: jsonc -*
//
// config.jsonc - waybar config
//

{
  // The order of the modules
  "modules-left": [
    "ext/workspaces",
    "dwl/window"
  ],
  "modules-center": [
    "clock",
    "custom/language"
  ],
  "modules-right": [
    "tray",
    "network",
    "bluetooth",
    "pulseaudio#output",
    "pulseaudio#input",
    "backlight",
    "idle_inhibitor",
    "power-profiles-daemon",
    "battery",
    "custom/exit"
  ],

  // Modules configuration

 "ext/workspaces": {
    //"on-scroll-up": "hyprctl dispatch workspace r-1",
    //"on-scroll-down": "[[ $(hyprctl activeworkspace -j | jq -r '.id') -lt 5 ]] && hyprctl dispatch workspace r+1 || hyprctl dispatch workspace 5",
    "ignore-hidden": false,
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": {
      "active": "¾░ä«"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  "ext/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "(.*) - Mozilla Thunderbird": "$1",
      "(.*) ŌĆö Mozilla Firefox": "$1",
      "(.*) - Text Editor": "$1"
    },
    "separate-outputs": true,
    "tooltip": false
  },

  "clock": {
    "format": "{:%d %b  %R}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>"
  },

  "custom/language": {
    "format": "{text}",
    "exec": "mmsg -k | cut -d \" \" -f 3",
    "on-click": "mmsg -d switch_keyboard_layout; pkill -SIGRTMIN+1 waybar",
    "signal": 1
    //"on-click": "hyprctl switchxkblayout all next"
  },

  "network": {
    "format": "¾░īś",
    "format-wifi": "{icon}",
    "format-icons": ["¾░ó╝", "¾░óĮ", "¾░óŠ"],
    "format-ethernet": "¾░łĆ  {ifname}",
    "format-disabled": "¾░ĆØ",
    "format-disconnected": "¾░īÖ",
    "tooltip-format": "¾░łĆ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "¾▒äÖ\t{ifname}\n’ć½\t{essid} @ {frequency}MHz\n¾░®Ā\t{ipaddr}\n¾░óŠ\t{signalStrength}%\n’éō\t{bandwidthUpBits}\n’ĆÖ\t{bandwidthDownBits}",
    "tooltip-format-ethernet": "¾░łĆ\t{ifname}\n¾░®Ā\t{ipaddr}\n’éō\t{bandwidthUpBits}\n’ĆÖ\t{bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "tooltip-format-disabled": "Network disabled",
    "max-length": 30,
    "on-click": "kitty nmtui"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 4
  },
  
  "bluetooth": {
    "format": "¾░é»",
    "format-disabled": "¾░é»",
    "format-connected": "¾░é▒",
    "format-off": "¾░é▓",
    "interval": 30,
    "on-click": "kitty bluetuith",
    "format-no-controller": "",
    "tooltip-format-connected": "Connected devices: {num_connections}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias} ¾░ü╣\t{device_battery_percentage}%"
  },
  
  "pulseaudio#output": {
    "scroll-step": 5, // %, can be a float
    "format": "{icon}",
    "format-bluetooth": "{icon}’Ŗö",
    "format-bluetooth-muted": "¾░Ø¤ ’Ŗö",
    "format-muted": "¾░Ø¤",
    "format-source": "’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’¢É ",
      "headset": "’¢É ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
    },
    "on-click": "pavucontrol",
    "tooltip": true,
    "tooltip-format": "¾░¢Ć\t{volume}%"
  },

  "pulseaudio#input": {
    "scroll-step": 5, // %, can be a float
    "format": "{format_source}",
    "format-source": "’ä░",
    "format-source-muted": "’ä▒",
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "backlight": {
    "format": "{icon}",
    "format-icons": "¾░¢©",
    "scroll-step": 5,
    "tooltip": true,
    "tooltip-format": "¾░¢©\t{percent}%"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    },
    "tooltip": false
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "¾░ŖÜ\t{profile}",
    "tooltip": true,
    "format-icons": {
      "default": "¾░ŖÜ",
      "performance": "¾░Ī┤",
      "balanced": "¾░ŖÜ",
      "power-saver": "¾░Ī│"
    }
  },

  "battery": {
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon}",
    "format-charging": "¾░éä",
    "format-plugged": "’ć”",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
    "tooltip": true,
    "tooltip-format": "¾░ü╣\t {capacity}%\n¾▒¦ź\t {time}"
  },

  "custom/exit": {
    "format": "’Ćæ",
    "on-click": "~/.local/bin/powermenu.sh",
    "tooltip": true,
    "tooltip-format": "Power menu"
  }
}
